{
	"name": "nevis-mobile-authentication-sdk-example-app-react",
	"version": "5.0.0",
	"private": true,
	"scripts": {
		"android": "react-native run-android --terminal terminal --active-arch-only",
		"android:clean": "del-cli android/build android/app/build android/app/.cxx && cd android && ./gradlew clean && cd ..",
		"android:run": "yarn android:clean && yarn android",
		"android:build": "yarn react-native build-android --mode Debug",
		"pods": "cd ios && bundle install && USE_FRAMEWORKS=static RCT_USE_PREBUILT_RNCORE=1 RCT_USE_RN_DEP=1 bundle exec pod install --repo-update && cd ..",
		"ios": "react-native run-ios --terminal terminal",
		"ios:clean": "del-cli ios/build/",
		"ios:run": "yarn ios:clean && yarn pods && yarn ios",
		"ios:build": "yarn pods && yarn react-native build-ios --mode Debug",
		"formatcheck": "yarn prettier -c \"src/**/*.{ts,tsx}\"",
		"lint": "eslint \"src/**/*.{ts,tsx}\"",
		"start": "react-native start",
		"check-dependencies": "rnx-align-deps --diff-mode allow-subset",
		"fix-dependencies": "rnx-align-deps --diff-mode allow-subset --write"
	},
	"dependencies": {
		"@nevis-security/nevis-mobile-authentication-sdk-react": ">=5.0.0-0 <5.1.0",
		"@react-native-community/hooks": "3.1.0",
		"@react-native-vector-icons/ant-design": "12.0.1",
		"@react-navigation/native": "7.2.2",
		"@react-navigation/native-stack": "7.14.2",
		"debounce": "3.0.0",
		"i18next": "25.2.1",
		"react": "19.2.3",
		"react-i18next": "15.5.2",
		"react-native": "0.85.2",
		"react-native-camera-kit": "17.0.1",
		"react-native-device-info": "15.0.2",
		"react-native-permissions": "5.4.4",
		"react-native-safe-area-context": "5.7.0",
		"react-native-screens": "4.24.0",
		"react-native-uuid": "2.0.3",
		"set-cookie-parser": "3.0.1"
	},
	"devDependencies": {
		"@babel/core": "7.28.5",
		"@babel/preset-env": "7.28.5",
		"@babel/runtime": "7.28.4",
		"@eslint/compat": "1.4.1",
		"@eslint/js": "9.39.1",
		"@react-native-community/cli": "20.1.3",
		"@react-native-community/cli-platform-android": "20.1.3",
		"@react-native-community/cli-platform-ios": "20.1.3",
		"@react-native/babel-preset": "0.85.2",
		"@react-native/eslint-config": "0.85.2",
		"@react-native/jest-preset": "0.85.2",
		"@react-native/metro-config": "0.85.2",
		"@react-native/typescript-config": "0.85.2",
		"@rnx-kit/align-deps": "3.4.7",
		"@tsconfig/react-native": "3.0.8",
		"@types/react": "19.2.3",
		"@types/react-test-renderer": "19.1.0",
		"@types/set-cookie-parser": "2.4.10",
		"@typescript-eslint/eslint-plugin": "8.48.1",
		"@typescript-eslint/parser": "8.48.1",
		"del-cli": "7.0.0",
		"eslint": "9.39.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-import-resolver-typescript": "4.4.4",
		"eslint-plugin-import": "2.32.0",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-native": "5.0.0",
		"pod-install": "0.3.4",
		"prettier": "3.5.3",
		"react-test-renderer": "19.2.3",
		"typescript": "5.8.3"
	},
	"engines": {
		"node": ">= 22.11.0"
	},
	"packageManager": "yarn@3.6.4",
	"rnx-kit": {
		"kitType": "app",
		"alignDeps": {
			"requirements": [
				"react-native@0.85"
			],
			"capabilities": [
				"babel-preset-react-native",
				"community/cli",
				"community/cli-android",
				"community/cli-ios",
				"core",
				"core-android",
				"core-ios",
				"core/metro-config",
				"navigation/native",
				"react",
				"react-test-renderer",
				"safe-area"
			]
		}
	}
}
